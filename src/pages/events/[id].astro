---
import { client, type Event } from "../../library/microcms";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const response = await client.getList<Event>({ endpoint: "events" });
  const linkableTags = ["記念式典", "社内行事", "アーカイブ"];

  const eventsOnly = response.contents.filter(
    (content) => content.tags && content.tags.some(tag => linkableTags.includes(tag))
  );

  return eventsOnly.map((content) => ({
    params: { id: content.id },
    props: { event: content },
  }));
}

const { event } = Astro.props;
---

<Layout title={`${event.title} | イベント＆お知らせ | 株式会社 新ニホンテック`}>

  <!-- ヒーローセクション（infection.astro に合わせた bg-primary スタイル） -->
  <section class="bg-primary text-white py-24 relative overflow-hidden mt-16">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="section-container relative z-10 text-center">
      <span class="badge--event">Event Report</span>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">{event.title}</h1>
      {event.english_title && <p class="text-surface-alt font-eng tracking-widest uppercase mt-2">{event.english_title}</p>}
    </div>
  </section>

  <main class="pt-12 pb-20 bg-surface-alt min-h-screen">
    <div class="section-container max-w-5xl">

      <!-- パンくずリスト -->
      <nav class="breadcrumb">
        <a href="/"><i class="fas fa-home mr-1"></i>トップ</a>
        <a href="/events">イベント＆お知らせ</a>
        <span>{event.title}</span>
      </nav>

      <!-- フォトギャラリー -->
      {event.photo_gallery && event.photo_gallery.length > 0 && (
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-center text-primary mb-8">
            <span class="border-b-4 border-accent pb-1">PHOTO GALLERY</span>
          </h2>
          <p class="text-center text-text-muted text-sm mb-6">当日の様子をご紹介します</p>

          <div class="relative bg-black rounded-xl overflow-hidden shadow-2xl h-[300px] md:h-[500px]" id="gallery-container">

            {event.photo_gallery.map((item, index) => (
              <div class={`slide w-full h-full absolute transition-opacity duration-500 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`} data-index={index}>
                <img src={item.image.url} class="w-full h-full object-cover opacity-80" alt={item.photo_title}>
                <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black/80 to-transparent p-6 text-white">
                  <h3 class="text-xl font-bold">{item.photo_title}</h3>
                </div>
              </div>
            ))}

            <button id="prev-btn" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 text-white rounded-full p-3 transition backdrop-blur-sm z-20">
              <i class="fas fa-chevron-left text-xl"></i>
            </button>
            <button id="next-btn" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/20 hover:bg-white/40 text-white rounded-full p-3 transition backdrop-blur-sm z-20">
              <i class="fas fa-chevron-right text-xl"></i>
            </button>

            <div class="absolute bottom-4 right-4 flex space-x-2 z-20">
              {event.photo_gallery.map((_, index) => (
                <span class={`dot w-3 h-3 bg-white rounded-full transition ${index === 0 ? 'opacity-100' : 'opacity-50'}`} data-index={index}></span>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- 戻るボタン -->
      <div class="text-center mb-8">
        <a href="/events" class="btn-secondary">
          <i class="fas fa-arrow-left mr-2"></i> イベント一覧に戻る
        </a>
      </div>

    </div>
  </main>

</Layout>

<script>
  const setupSlider = () => {
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');

    if (slides.length <= 1) {
      document.getElementById('prev-btn')?.classList.add('hidden');
      document.getElementById('next-btn')?.classList.add('hidden');
      return;
    }

    let currentIndex = 0;
    let slideTimer: ReturnType<typeof setInterval>;

    const updateDisplay = () => {
      slides.forEach((slide, index) => {
        slide.classList.toggle('opacity-100', index === currentIndex);
        slide.classList.toggle('z-10', index === currentIndex);
        slide.classList.toggle('opacity-0', index !== currentIndex);
        slide.classList.toggle('z-0', index !== currentIndex);
      });
      dots.forEach((dot, index) => {
        dot.classList.toggle('opacity-100', index === currentIndex);
        dot.classList.toggle('opacity-50', index !== currentIndex);
      });
    };

    const nextSlide = () => {
      currentIndex = (currentIndex + 1) % slides.length;
      updateDisplay();
    };

    let timer = setInterval(nextSlide, 5000);
    const resetTimer = () => { clearInterval(timer); timer = setInterval(nextSlide, 5000); };

    document.getElementById('prev-btn')?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + slides.length) % slides.length;
      updateDisplay(); resetTimer();
    });
    document.getElementById('next-btn')?.addEventListener('click', () => {
      nextSlide(); resetTimer();
    });
  };

  document.addEventListener('DOMContentLoaded', setupSlider);
</script>