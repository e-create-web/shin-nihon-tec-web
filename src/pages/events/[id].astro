---
import { client, type Event } from "../../library/microcms";
import Layout from "../../layouts/Layout.astro";
import '../../styles/gallery.css';

// 動的ルートの設定
export async function getStaticPaths() {
  const response = await client.getList<Event>({ endpoint: "events" });
  
  // ページを生成するタグのリスト
  const linkableTags = ["記念式典", "社内行事", "アーカイブ"];

  // 上記のタグが含まれている記事だけを抽出してページを生成
  const eventsOnly = response.contents.filter(
    (content) => content.tags && content.tags.some(tag => linkableTags.includes(tag))
  );

  return eventsOnly.map((content) => ({
    params: { id: content.id },
    props: { event: content },
  }));
}

const { event } = Astro.props;
---

<Layout>
  <section class="bg-primary text-white py-24 relative overflow-hidden mt-16">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="section-container relative z-10 text-center">
      <span class="badge--event">Event Report</span>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">{event.title}</h1>
      {event.english_title && <p class="text-blue-200 font-eng tracking-widest uppercase">{event.english_title}</p>}
    </div>
  </section>

  <main class="section-container max-w-5xl py-12">

    <!-- パンくずリスト -->
    <nav class="breadcrumb">
      <a href="/"><i class="fas fa-home mr-1"></i>トップ</a>
      <a href="/events">イベント＆お知らせ</a>
      <span>{event.title}</span>
    </nav>

    {event.photo_gallery && event.photo_gallery.length > 0 && (
      <div class="mb-16">
        <h2 class="text-2xl font-bold text-center text-primary mb-8">
          <span class="border-b-4 border-accent pb-1">PHOTO GALLERY</span>
        </h2>
        <p class="text-center text-gray-500 text-sm mb-6">当日の様子をご紹介します</p>

        <!-- スライダー本体 -->
        <div class="relative bg-black rounded-xl overflow-hidden shadow-2xl h-[300px] md:h-[500px]" id="gallery-container">

          {event.photo_gallery.map((item, index) => (
            <div class={`slide w-full h-full absolute transition-opacity duration-500 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`} data-index={index} data-title={item.photo_title}>
              <img src={item.image.url} class="w-full h-full object-cover opacity-80" alt={item.photo_title}>
            </div>
          ))}

          <!-- 前へ / 次へ ボタン（common.css: .btn-gallery-nav） -->
          <button id="prev-btn" class="btn-gallery-nav left-4" aria-label="前の画像">
            <i class="fas fa-chevron-left text-xl"></i>
          </button>
          <button id="next-btn" class="btn-gallery-nav right-4" aria-label="次の画像">
            <i class="fas fa-chevron-right text-xl"></i>
          </button>

          <!-- 下部バー：左=タイトル／中央=ドット／右=全画面ボタン（gallery.css: .gallery-bar） -->
          <div class="gallery-bar">
            <div class="gallery-bar__inner">

              <!-- 左：タイトル -->
              <div class="gallery-bar__title">
                <p id="slide-title" class="gallery-bar__title-text"></p>
              </div>

              <!-- 中央：ドット -->
              <div class="gallery-bar__dots">
                {event.photo_gallery.map((_, index) => (
                  <span class={`dot w-2.5 h-2.5 bg-white rounded-full transition ${index === 0 ? 'opacity-100' : 'opacity-50'}`} data-index={index}></span>
                ))}
              </div>

              <!-- 右：全画面ボタン（gallery.css: .gallery-bar__action） -->
              <div class="gallery-bar__action">
                <button id="fullscreen-btn" class="w-9 h-9 flex items-center justify-center bg-white/20 hover:bg-white/40 text-white rounded-full transition backdrop-blur-sm" aria-label="全画面表示">
                  <i class="fas fa-expand text-base"></i>
                </button>
              </div>

            </div>
          </div>

        </div>
      </div>
    )}

    <div class="text-center mb-8">
      <a href="/events" class="btn-back">
        イベント一覧に戻る
      </a>
    </div>
  </main>

  <!-- ライトボックス モーダル（gallery.css: .lightbox） -->
  <div id="lightbox" class="lightbox" style="display: none;">

    <!-- 閉じるボタン（gallery.css: .lightbox__close） -->
    <button id="lightbox-close" class="lightbox__close" aria-label="閉じる">
      <i class="fas fa-times text-xl"></i>
    </button>

    <!-- 画像エリア（gallery.css: .lightbox__image-area） -->
    <div class="lightbox__image-area">
      <img id="lightbox-img" src="" alt="" class="lightbox__img" />
    </div>

    <!-- 前へ / 次へ ボタン（gallery.css: .lightbox__nav） -->
    <button id="lightbox-prev" class="lightbox__nav left-3" aria-label="前の画像">
      <i class="fas fa-chevron-left text-xl"></i>
    </button>
    <button id="lightbox-next" class="lightbox__nav right-3" aria-label="次の画像">
      <i class="fas fa-chevron-right text-xl"></i>
    </button>

    <!-- 下部バー：左=タイトル／中央=ドット（gallery.css: .lightbox__bar） -->
    <div class="lightbox__bar">
      <div class="gallery-bar__inner">

        <!-- 左：タイトル -->
        <div class="gallery-bar__title">
          <p id="lightbox-caption" class="gallery-bar__title-text"></p>
        </div>

        <!-- 中央：ドット（JSで生成） -->
        <div id="lightbox-dots" class="gallery-bar__dots"></div>

        <!-- 右：スペーサー -->
        <div class="gallery-bar__action"></div>

      </div>
    </div>

  </div>

  <script src="/assets/js/event.js" is:inline></script>

</Layout>