---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import { client, type Event } from '../../library/microcms';

const response = await client.getList<Event>({ endpoint: "events", queries: { limit: 100 } });
const events = response.contents;

const tagColors: Record<string, string> = {
  "お知らせ":   "bg-accent-muted text-accent font-bold",
  "Web更新":    "bg-accent-muted text-accent font-bold",
  "実績紹介":   "bg-primary text-white",
  "記念式典":   "bg-accent text-white",
  "社内行事":   "bg-accent text-white",
  "アーカイブ": "bg-text-muted text-white",
  "その他":     "bg-text-muted text-white",
};

const allTags = Array.from(new Set(events.flatMap(e => e.tags || [])));
const linkableTags = ["記念式典", "社内行事", "アーカイブ"];
---

<Layout title="イベント＆お知らせ | 株式会社 新ニホンテック">
    <main class="pt-32 pb-20 bg-surface-alt min-h-screen">
        <div class="section-container max-w-4xl">

            <!-- パンくずリスト -->
            <nav class="breadcrumb">
                <a href="/"><i class="fas fa-home mr-1"></i>トップ</a>
                <span>イベント＆お知らせ</span>
            </nav>

            <!-- ページタイトル -->
            <div class="text-center mb-12 md:mb-16">
                <span class="section-eyebrow">Events & Announcements</span>
                <h1 class="section-title tracking-wider">イベント＆お知らせ</h1>
                <div class="section-divider"></div>
            </div>

            <div class="bg-surface rounded-xl shadow-lg p-6 md:p-10 border border-border">

                <!-- 絞り込みボタン -->
                <div class="mb-8 border-b border-border pb-6">
                    <div class="flex flex-wrap gap-2" id="tag-filters">
                        <button class="filter-btn active px-4 py-2 rounded-full text-sm font-bold transition bg-primary text-white shadow-md" data-tag="all">
                            すべて
                        </button>
                        {allTags.map(tag => (
                            <button class="filter-btn px-4 py-2 rounded-full text-sm font-bold transition bg-surface-alt text-primary hover:bg-border border border-border" data-tag={tag}>
                                {tag}
                            </button>
                        ))}
                    </div>
                </div>

                <!-- イベントリスト -->
                <div id="event-list" class="space-y-4 min-h-[400px]">
                    {events.map((event) => {
                        const hasLink = event.tags && event.tags.some(tag => linkableTags.includes(tag));
                        const tagsString = event.tags ? event.tags.join(',') : '';

                        return hasLink ? (
                            <a href={`/events/${event.id}`} class="event-item block p-4 border border-border rounded-lg bg-surface hover:shadow-md hover:border-primary transition duration-300 group" data-tags={tagsString}>
                                <div class="flex flex-col md:flex-row md:items-center gap-2 mb-2">
                                    <span class="text-sm text-text-muted w-24 shrink-0 font-eng">{new Date(event.date).toLocaleDateString("ja-JP")}</span>
                                    <div class="flex flex-wrap gap-1">
                                        {event.tags && event.tags.map(tag => (
                                            <span class={`px-2 py-0.5 rounded text-xs ${tagColors[tag] || tagColors["その他"]}`}>{tag}</span>
                                        ))}
                                    </div>
                                </div>
                                <h2 class="text-lg font-bold text-primary group-hover:text-accent transition md:ml-26">
                                    {event.content}
                                </h2>
                            </a>
                        ) : (
                            <div class="event-item block p-4 border border-border rounded-lg bg-surface-alt/50" data-tags={tagsString}>
                                <div class="flex flex-col md:flex-row md:items-center gap-2 mb-2">
                                    <span class="text-sm text-text-muted w-24 shrink-0 font-eng">{new Date(event.date).toLocaleDateString("ja-JP")}</span>
                                    <div class="flex flex-wrap gap-1">
                                        {event.tags && event.tags.map(tag => (
                                            <span class={`px-2 py-0.5 rounded text-xs ${tagColors[tag] || tagColors["その他"]}`}>{tag}</span>
                                        ))}
                                    </div>
                                </div>
                                <h2 class="text-lg font-bold text-primary md:ml-26">
                                    {event.content}
                                </h2>
                            </div>
                        );
                    })}
                </div>

                <!-- ページネーション -->
                <div id="pagination" class="flex justify-center items-center gap-2 mt-10"></div>

            </div>

            <!-- 戻るボタン -->
            <div class="text-center mt-12 mb-8">
                <a href="/" class="btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i> トップページへ戻る
                </a>
            </div>

        </div>
    </main>

    <Contact />

</Layout>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
    const ITEMS_PER_PAGE = 10;
    let currentPage = 1;
    let currentFilter = 'all';

    const items = Array.from(document.querySelectorAll('.event-item'));
    const filterBtns = document.querySelectorAll('.filter-btn');
    const paginationContainer = document.getElementById('pagination');
    const eventListContainer = document.getElementById('event-list');

    function render() {
        const filteredItems = items.filter(item => {
            if (currentFilter === 'all') return true;
            const tags = item.getAttribute('data-tags').split(',');
            return tags.includes(currentFilter);
        });

        const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE);
        if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

        const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
        const endIndex = startIndex + ITEMS_PER_PAGE;

        items.forEach(item => item.style.display = 'none');
        filteredItems.slice(startIndex, endIndex).forEach(item => {
            item.style.display = 'block';
        });

        renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
        paginationContainer.innerHTML = '';
        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement('button');
            btn.textContent = i;
            btn.className = i === currentPage
                ? 'w-10 h-10 rounded-full flex items-center justify-center font-bold bg-accent text-white shadow-md'
                : 'w-10 h-10 rounded-full flex items-center justify-center font-bold bg-surface-alt text-primary hover:bg-border border border-border transition cursor-pointer';

            btn.addEventListener('click', () => {
                currentPage = i;
                render();
                window.scrollTo({ top: eventListContainer.offsetTop - 100, behavior: 'smooth' });
            });

            paginationContainer.appendChild(btn);
        }
    }

    filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            filterBtns.forEach(b => {
                b.classList.remove('bg-primary', 'text-white', 'shadow-md');
                b.classList.add('bg-surface-alt', 'text-primary');
            });
            e.currentTarget.classList.remove('bg-surface-alt', 'text-primary');
            e.currentTarget.classList.add('bg-primary', 'text-white', 'shadow-md');

            currentFilter = e.currentTarget.getAttribute('data-tag');
            currentPage = 1;
            render();
        });
    });

    render();
});
</script>