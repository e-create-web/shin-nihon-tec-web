---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import { client, type Event } from '../../library/microcms';

// microCMSからイベントデータを全件（または多めに）取得
// ※件数が多い場合は limit: 100 などを指定してください
const response = await client.getList<Event>({ endpoint: "events", queries: { limit: 100 } });
const events = response.contents;

// タグのカラー辞書（トップページと同じもの）
const tagColors: Record<string, string> = {
  "お知らせ": "bg-accent-muted text-accent font-bold",
  "Web更新": "bg-accent-muted text-accent font-bold",
  "実績紹介": "bg-primary text-white",
  "記念式典": "bg-accent text-white",
  "社内行事": "bg-accent text-white",
  "アーカイブ": "bg-text-muted text-white",
  "その他": "bg-text-muted text-white",
};

// 重複のない全タグのリストを作成（絞り込みボタン用）
const allTags = Array.from(new Set(events.flatMap(e => e.tags || [])));

// 詳細ページへの遷移を許可するタグ
const linkableTags = ["記念式典", "社内行事", "アーカイブ"];
---

<Layout title="イベント＆お知らせ | 株式会社 新ニホンテック">
    <div class="pt-24 pb-20 bg-surface-alt min-h-screen">
        <div class="section-container max-w-4xl">
            
            <!-- パンくずリスト -->
            <nav class="breadcrumb">
                <a href="/"><i class="fas fa-home mr-1"></i>トップ</a>
                <span>イベント＆お知らせ</span>
            </nav>

            <!-- タイトル -->
            <div class="section-header mb-12 md:mb-20">
                <span class="section-eyebrow">Events & Announcements</span>
                <h1 class="section-title tracking-wider">イベント＆お知らせ</h1>
                <div class="section-divider"></div>
            </div>

            <div class="bg-surface rounded-xl shadow-lg p-6 md:p-10">
                
                <div class="mb-8 border-b border-border pb-6">
                    <div class="flex flex-wrap gap-2" id="tag-filters">
                        <button class="filter-btn active px-4 py-2 rounded-full text-sm font-bold transition bg-primary text-white shadow-md" data-tag="all">
                            すべて
                        </button>
                        {allTags.map(tag => (
                            <button class="filter-btn px-4 py-2 rounded-full text-sm font-bold transition bg-surface-alt text-primary hover:bg-gray-200 border border-border" data-tag={tag}>
                                {tag}
                            </button>
                        ))}
                    </div>
                </div>

                <div id="event-list" class="space-y-4 min-h-[400px]">
                    {events.map((event) => {
                        const hasLink = event.tags && event.tags.some(tag => linkableTags.includes(tag));
                        // JSでの絞り込み用に、タグをカンマ区切りの文字列としてdata属性に持たせる
                        const tagsString = event.tags ? event.tags.join(',') : '';

                        return hasLink ? (
                            <a href={`/events/${event.id}`} class="event-item block p-4 border border-border rounded-lg hover:shadow-md transition group bg-white" data-tags={tagsString}>
                                <div class="event-meta mb-2 md:flex-row md:items-center gap-2">
                                    <span class="text-sm text-text-muted w-24 shrink-0">{new Date(event.date).toLocaleDateString("ja-JP")}</span>
                                    <div class="flex flex-wrap gap-1">
                                        {event.tags && event.tags.map(tag => (
                                            <span class={`px-2 py-0.5 rounded text-xs ${tagColors[tag] || tagColors["その他"]}`}>{tag}</span>
                                        ))}
                                    </div>
                                </div>
                                <h2 class="text-lg font-bold text-primary group-hover:text-accent transition md:ml-26">
                                    {event.content}
                                </h2>
                            </a>
                        ) : (
                            <div class="event-item block p-4 border border-border rounded-lg bg-surface-alt" data-tags={tagsString}>
                                <div class="event-meta mb-2 md:flex-row md:items-center gap-2">
                                    <span class="text-sm text-text-muted w-24 shrink-0">{new Date(event.date).toLocaleDateString("ja-JP")}</span>
                                    <div class="flex flex-wrap gap-1">
                                        {event.tags && event.tags.map(tag => (
                                            <span class={`px-2 py-0.5 rounded text-xs ${tagColors[tag] || tagColors["その他"]}`}>{tag}</span>
                                        ))}
                                    </div>
                                </div>
                                <h2 class="text-lg font-bold text-primary md:ml-26">
                                    {event.content}
                                </h2>
                            </div>
                        );
                    })}
                </div>

                <div id="pagination" class="flex justify-center items-center gap-2 mt-10">
                </div>

            </div>

            <div class="mt-16 md:mt-20 text-center">
                <a href="/" class="btn-back">
                    トップページへ戻る
                </a>
            </div>
        </div>
    </div>

    <Contact />

</Layout>

<script src="/assets/js/events-list.js" is:inline></script>