---
import Layout from '../layouts/Layout.astro';

import Hero from '../components/Hero.astro';

import About from '../components/About.astro';
import Company from '../components/Company.astro';
import Strength from '../components/Strength.astro';
import Service from '../components/Service.astro';
import Works from '../components/Works.astro';
import Workflow from '../components/Workflow.astro';
import Special from '../components/Special.astro';
import Recruit from '../components/Recruit.astro';
import Access from '../components/Access.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
    <section class="h-screen min-h-[600px] mt-16 relative">
        <div class="swiper myHeroSwiper w-full h-full">
            <div class="swiper-wrapper">

                <div class="swiper-slide relative bg-gray-900 flex items-center">
                    <Opening />
                </div>

                <div class="swiper-slide relative bg-gray-900 flex items-center">
                    <Hero />
                </div>

                <div class="swiper-slide relative bg-surface-alt flex flex-col items-center justify-center">
                    <Live />
                </div>

            </div>

            <div class="swiper-pagination"></div>
            <div class="swiper-button-next !text-white drop-shadow"></div>
            <div class="swiper-button-prev !text-white drop-shadow"></div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" is:inline></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        const swiper = new Swiper('.myHeroSwiper', {
          loop: false, // Openingを最初に1度だけ表示するためloopはOFF
          initialSlide: 0,

          autoplay: false, // Opening演出中はautoplay無効（演出完了後に有効化）

          speed: 1000, // スライドのトランジション時間（ms）

          effect: 'fade',
          fadeEffect: {
            crossFade: true,
          },

          allowTouchMove: false, // Opening中はスワイプ操作を禁止

          pagination: {
            el: '.swiper-pagination',
            clickable: true,
          },

          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
          },
        });

        // Opening演出完了後にHeroスライドへ移行し、通常のSwiper操作を開始する
        window.onOpeningComplete = function () {
          swiper.slideNext(1000); // 1000msのトランジションでHeroへ移動

          setTimeout(function () {
            swiper.allowTouchMove = true; // スワイプ操作を解放
            swiper.autoplay.start();      // 自動再生を開始
            swiper.params.loop = true;    // ループを有効化
            swiper.update();
          }, 900);
        };
      });
    </script>

    <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
        const swiper = new Swiper('.myHeroSwiper', {
        loop: false,
        initialSlide: 0,
        autoplay: false,
        speed: 1000,
        effect: 'fade',
        fadeEffect: { crossFade: true },
        allowTouchMove: false, // 最初は操作禁止
        pagination: { el: '.swiper-pagination', clickable: true },
        navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
        });

        // オープニング演出の時間（4.5秒）
        const OPENING_DURATION = 4500;

        // 最初の1回だけ実行されるタイマー
        setTimeout(function() {
        // 演出が終わったらHeroへ移動
        swiper.slideNext(1000);

        // 移動完了後にループや操作を有効化
        setTimeout(function () {
            swiper.allowTouchMove = true; 
            swiper.autoplay.start({
            delay: 5000,
            disableOnInteraction: false,
            });
            swiper.params.loop = true;
            swiper.update(); // ループ設定を反映
        }, 1000);
        }, OPENING_DURATION);
    });
    </script>

    <About />
    <Company />
    <Strength />
    <Service />
    <Works />
    <Workflow />
    <Special />
    <Recruit />
    <Access />
    <Contact />

    <script src="/assets/js/common.js" is:inline></script>
    <script src="/assets/js/top.js" is:inline></script>
</Layout>