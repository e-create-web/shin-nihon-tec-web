---
import Layout from '../layouts/Layout.astro';

import Hero from '../components/Hero.astro';

import About from '../components/About.astro';
import Company from '../components/Company.astro';
import Strength from '../components/Strength.astro';
import Service from '../components/Service.astro';
import Works from '../components/Works.astro';
import Workflow from '../components/Workflow.astro';
import Special from '../components/Special.astro';
import Recruit from '../components/Recruit.astro';
import Access from '../components/Access.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
    <div id="opening-splash">

        <!-- 背景画像＋オーバーレイ -->
        <div class="splash-bg">
            <img src="/assets/images/image1.jpg" class="splash-bg-img" alt="Opening">
            <div class="splash-bg-overlay"></div>
        </div>

        <!-- テキストコンテンツ -->
        <div class="splash-content">
            <span class="splash-label">ESTABLISHED IN</span>
            <span class="splash-year">1946</span>
            <div class="splash-divider"></div>
            <p class="splash-text">
                おかげさまで創業80周年<br>
                株式会社 新ニホンテック<br>
                <span class="splash-text-sub">SHINNIHON TEC CO., LTD.</span>
            </p>
        </div>

        <!-- SKIPボタン -->
        <button onclick="skipAnimation()" class="splash-skip-btn">
            SKIP <i class="fas fa-chevron-right ml-1"></i>
        </button>

    </div>

    <Hero />

    <About />
    <Company />
    <Strength />
    <Service />
    <Works />
    <Workflow />
    <Special />
    <Recruit />
    <Access />
    <Contact />
    
    <script src="/assets/js/common.js" is:inline></script>
    <script src="/assets/js/top.js" is:inline></script>

</Layout>