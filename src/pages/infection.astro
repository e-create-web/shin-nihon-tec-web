---
// ※ファイルの保存場所（階層）に合わせてLayoutのパスを調整してください
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="特設ページ：感染症対策 | 株式会社新二ホンテック">
    <main class="pt-32 pb-20 bg-surface-alt min-h-screen">
        <div class="section-container max-w-4xl">
            
            <!-- パンくずリスト -->
            <nav class="breadcrumb">
                <a href="/"><i class="fas fa-home mr-1"></i>トップ</a>
                <span>感染症対策</span>
            </nav>

            <div class="text-center mb-12 md:mb-20">
                <span class="section-eyebrow">Infection Control</span>
                <h1 class="section-title tracking-wider">感染症対策</h1>
                <div class="section-divider"></div>
            </div>

            <div class="space-y-12 md:space-y-16">
                
                <section class="bg-surface p-6 md:p-10 rounded-lg border border-border shadow-md transition duration-300 hover:shadow-xl hover:-translate-y-1 text-left">
                    <div class="flex items-start gap-4 md:gap-6 mb-8 md:mb-10">
                        <div class="icon-circle--surface">
                            <i class="fas fa-hands-wash"></i>
                        </div>
                        <div>
                            <h3 class="text-xl md:text-2xl font-bold text-primary mb-2">指先消毒、除菌</h3>
                            <p class="text-base text-text leading-relaxed">
                                玄関や居室の入口にアルコール消毒液を設置しています。
                            </p>
                        </div>
                    </div>

                    <div class="w-full rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                        <img src="/assets/special_images/image6.jpg" alt="アルコール消毒液の設置場所" class="w-full h-auto" />
                    </div>
                </section>

                <section class="bg-surface p-6 md:p-10 rounded-lg border border-border shadow-md transition duration-300 hover:shadow-xl hover:-translate-y-1 text-left">
                    <div class="flex items-start gap-4 md:gap-6 mb-8 md:mb-10">
                        <div class="icon-circle--surface">
                            <i class="fas fa-wind"></i>
                        </div>
                        <div>
                            <h3 class="text-xl md:text-2xl font-bold text-primary mb-2">空間除菌</h3>
                            <p class="text-base text-text leading-relaxed">
                                各居室に次亜塩素酸 空間除菌脱臭機を設置しています。
                            </p>
                        </div>
                    </div>
                    <div class="w-full md:w-1/2 mx-auto rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                        <img src="/assets/special_images/IMG_0216.jpg" alt="アルコール消毒液の設置場所" class="w-full h-auto" />
                    </div>
                </section>

                <section class="bg-surface p-6 md:p-10 rounded-lg border border-border shadow-md transition duration-300 hover:shadow-xl hover:-translate-y-1 text-left">
                    <div class="flex items-start gap-4 md:gap-6 mb-8 md:mb-10">
                        <div class="icon-circle--surface">
                            <i class="fas fa-people-arrows"></i>
                        </div>
                        <div>
                            <h3 class="text-xl md:text-2xl font-bold text-primary mb-2">飛沫対策</h3>
                            <p class="text-base text-text leading-relaxed">
                                個人デスク間を抗菌フィルムで隔離しています。
                            </p>
                        </div>
                    </div>

                    <div class="w-full rounded-lg shadow-sm border border-border overflow-hidden bg-light">
                        <img src="/assets/special_images/EKURI2.jpg" alt="デスクに設置された抗菌フィルムとパネル" class="w-full h-auto" />
                    </div>
                </section>
            </div>
            
            <div class="mt-16 md:mt-20 text-center">
                <a href="/" class="btn-secondary">
                    トップページへ戻る
                </a>
            </div>

        </div>
    </main>

    <Contact />

    <script src="/assets/js/common.js" is:inline></script>

</Layout>