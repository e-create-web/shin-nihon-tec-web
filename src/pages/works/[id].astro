---
import { getWorks } from "../../library/microcms";
import Layout from "../../layouts/Layout.astro";

// 動的ルートの設定
export async function getStaticPaths() {
  const response = await getWorks({ limit: 100 });
  return response.contents.map((content) => ({
    params: { id: content.id },
    props: { work: content },
  }));
}

const { work } = Astro.props;

// カテゴリと画像の取得処理
const catArray = Array.isArray(work.category) ? work.category : (work.category ? [work.category] : []);
const displayCategory = catArray.length > 0 ? catArray[0] : '';
const imgUrl = work['top-image'] ? work['top-image'].url : '';
---

<Layout title={`${work.title} | 開発・製作実績 | 株式会社 新ニホンテック`}>
  <section class="bg-primary text-white py-24 relative overflow-hidden mt-16">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      {displayCategory && (
        <span class="inline-block bg-accent text-white text-xs font-bold px-3 py-1 rounded-full mb-4 tracking-wider">{displayCategory}</span>
      )}
      <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight">{work.title}</h1>
      {work.location && <p class="text-blue-200 tracking-widest"><i class="fas fa-map-marker-alt mr-2"></i>{work.location}</p>}
    </div>
  </section>

  <main class="container mx-auto px-4 max-w-4xl py-12">

    <!-- パンくずリスト -->
    <div class="text-sm text-gray-500 mb-10 flex items-center">
      <a href="/" class="hover:text-accent transition font-bold"><i class="fas fa-home mr-1"></i>トップ</a> 
      <span class="mx-2">&rsaquo;</span>
      <a href="/works" class="hover:text-accent transition font-bold">開発・製作実績</a> 
      <span class="mx-2">&rsaquo;</span>
      <span class="text-gray-800 font-bold truncate">{work.title}</span>
    </div>

    <!-- トップ画像 -->
    {imgUrl && (
        <div class="mb-12 rounded-2xl overflow-hidden shadow-lg border border-gray-100">
            <img src={imgUrl} alt={work.title} class="w-full h-auto md:max-h-[500px] object-cover hover:scale-105 transition duration-700" />
        </div>
    )}

    <!-- 本文 (リッチエディタ) -->
    {work.content && (
        <div class="bg-white p-8 md:p-12 rounded-2xl shadow-sm border border-gray-100">
            <div class="prose max-w-none text-gray-700 leading-relaxed" set:html={work.content}></div>
        </div>
    )}

    <!-- 戻るボタン -->
    <div class="text-center mt-12 mb-8">
      <a href="/works" class="inline-flex items-center justify-center bg-white border-2 border-primary text-primary font-bold py-3 px-10 rounded-full hover:bg-primary hover:text-white transition shadow-sm">
        <i class="fas fa-arrow-left mr-2"></i> 実績一覧に戻る
      </a>
    </div>

  </main>
</Layout>