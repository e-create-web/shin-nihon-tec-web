---
import { getWorks } from "../../library/microcms";
import Layout from "../../layouts/Layout.astro";

// 動的ルートの設定
export async function getStaticPaths() {
  const response = await getWorks({ limit: 100 });
  return response.contents.map((content) => ({
    params: { id: content.id },
    props: { work: content },
  }));
}

const { work } = Astro.props;

// カテゴリと画像の取得処理
const catArray = Array.isArray(work.category) ? work.category : (work.category ? [work.category] : []);
const displayCategory = catArray.length > 0 ? catArray[0] : '';
const imgUrl = work['top-image'] ? work['top-image'].url : '';
---

<Layout title={`${work.title} | 開発・製作実績 | 株式会社 新ニホンテック`}>

  <!-- ヒーローセクション（events/[id].astro と同じ構造で統一） -->
  <section class="bg-primary text-white py-24 relative overflow-hidden mt-16">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="section-container relative z-10 text-center">
      {displayCategory && (
        <span class="badge--event">{displayCategory}</span>
      )}
      <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight">{work.title}</h1>
      {work.location && (
        <p class="text-surface-alt tracking-widest mt-2">
          <i class="fas fa-map-marker-alt mr-2"></i>{work.location}
        </p>
      )}
    </div>
  </section>

  <main class="pt-12 pb-20 bg-surface-alt min-h-screen">
    <div class="section-container max-w-4xl">

      <!-- パンくずリスト -->
      <nav class="breadcrumb">
        <a href="/"><i class="fas fa-home mr-1"></i>トップ</a>
        <a href="/works">開発・製作実績</a>
        <span>{work.title}</span>
      </nav>

      <!-- トップ画像 -->
      {imgUrl && (
        <div class="mb-12 rounded-2xl overflow-hidden shadow-lg border border-border">
          <img src={imgUrl} alt={work.title} class="w-full h-auto md:max-h-[500px] object-cover hover:scale-105 transition duration-700" />
        </div>
      )}

      <!-- 本文（リッチエディタ） -->
      {work.content && (
        <div class="bg-surface p-8 md:p-12 rounded-2xl shadow-sm border border-border mb-12">
          <div class="prose max-w-none text-text-body leading-relaxed" set:html={work.content}></div>
        </div>
      )}

      <!-- 戻るボタン -->
      <div class="text-center mb-8">
        <a href="/works" class="btn-back">
          <i class="fas fa-arrow-left mr-2"></i> 実績一覧に戻る
        </a>
      </div>

    </div>
  </main>

</Layout>