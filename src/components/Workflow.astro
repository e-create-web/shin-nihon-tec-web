---
// Workflow バージョンB: ステップデータを配列で定義してループする版

const steps = [
    {
        number: "01",
        color: "bg-accent",
        title: "お問い合わせ",
        description: "お電話またはメールより\nご連絡ください。",
    },
    {
        number: "02",
        color: "bg-primary",
        title: "現地調査",
        description: "担当者が伺い、\n現場確認とヒアリングを\nします。",
    },
    {
        number: "03",
        color: "bg-primary",
        title: "お見積り・設計",
        description: "お見積り承認後、\n詳細設計を行います。",
    },
    {
        number: "04",
        color: "bg-primary",
        title: "製作・施工",
        description: "安全・品質管理を徹底し\n作業を進めます。",
    },
    {
        number: "05",
        color: "bg-accent-hover",
        title: "動作試験・納品",
        description: "動作確認を行い\nお引き渡しします。",
    },
];
---

<section id="workflow" class="py-20 bg-surface border-t border-border">
    <div class="section-container">
        <div class="section-header">
            <h2 class="section-title">ご依頼の流れ</h2>
            <div class="section-divider mb-4"></div>
            <p class="text-text-body">お問い合わせから納品まで、丁寧に対応させていただきます。</p>
        </div>
        
        <div class="flex flex-col md:flex-row justify-between items-start max-w-5xl mx-auto relative">
            <div class="hidden md:block absolute top-1/2 left-0 w-full h-1 bg-border -z-10 transform -translate-y-1/2"></div>

            {steps.map((step) => (
                <div class="workflow-step">
                    <div class={`workflow-step-circle ${step.color}`}>{step.number}</div>
                    <h3 class="font-bold text-primary mb-2">{step.title}</h3>
                    <p class="text-xs text-center text-text-muted">
                        {step.description.split('\n').map((line, i, arr) => (
                            <>
                                {line}
                                {i < arr.length - 1 && <br />}
                            </>
                        ))}
                    </p>
                </div>
            ))}
        </div>
    </div>
</section>