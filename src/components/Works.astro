---
import { getWorks } from '../library/microcms';

// microCMSから最新3件を取得
const response = await getWorks({ limit: 3 });
const works = response.contents;
---

<section id="works" class="py-24 bg-light">
    <div class="section-container">
        <!-- セクションヘッダー -->
        <div class="section-header">
            <h2 class="section-title">開発・製作実績</h2>
            <div class="section-divider"></div>
        </div>
        
        <!-- 実績カード -->
        <div class="grid md:grid-cols-3 gap-6">
            {works.map((work) => {
                const catArray = Array.isArray(work.category)
                    ? work.category
                    : (work.category ? [work.category] : []);
                const displayCategory = catArray.length > 0 ? catArray[0] : '';
                const imgUrl = work['top-image']
                    ? work['top-image'].url
                    : '/assets/images/logo.png';

                return (
                    <a href={`/works/${work.id}`} class="card--works group">
                        <div class="overflow-hidden h-48 relative">
                            <img
                                src={imgUrl}
                                class="w-full h-full object-cover group-hover:scale-110 transition duration-500"
                                alt={work.title}
                            />
                            {displayCategory && (
                                <div class="absolute top-2 left-2">
                                    <span class="badge--primary">{displayCategory}</span>
                                </div>
                            )}
                        </div>
                        <div class="p-4">
                            <h3 class="font-bold text-lg mb-2 text-primary group-hover:text-accent transition line-clamp-2">
                                {work.title}
                            </h3>
                            {work.location && (
                                <p class="text-sm text-text-muted">
                                    <i class="fas fa-map-marker-alt mr-1"></i>{work.location}
                                </p>
                            )}
                        </div>
                    </a>
                );
            })}
        </div>

        <div class="mt-16 md:mt-20 text-center">
            <a href="/works" class="btn-secondary">
                一覧を見る
            </a>
        </div>

    </div>
</section>