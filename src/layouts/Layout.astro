---
// ここはAstroのプログラムを書く場所です（今回はCSSを読み込みます） 
import '../styles/common.css';
import '../styles/top.css';
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>株式会社 新ニホンテック | 技術と誠意で80年、そして100年へ</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Oswald:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/images/logo.png" />
</head>
<body class="text-text-body scroll-smooth bg-light flex flex-col min-h-screen">

    <!-- ヘッダー -->
    <header class="header-nav">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <!-- ロゴ -->
            <a href="/" class="header-brand group">
                <img src="/assets/images/logo.png" alt="新ニホンテック" class="h-10 md:h-12 w-auto mr-3 group-hover:opacity-80 transition">
                <div>
                    <span class="block text-xs md:text-sm text-text-muted font-normal">電気工事・自動制御・CO2削減</span>
                    株式会社 新ニホンテック
                </div>
            </a>
            
            <!-- デスクトップナビゲーション -->
            <nav class="hidden xl:flex space-x-6 text-sm font-bold text-primary items-center">
                <!-- 企業情報 -->
                <div class="relative group py-2">
                    <a href="/#about" class="nav-dropdown-trigger">企業情報</a>
                    <div class="nav-dropdown-menu w-48">
                        <a href="/#about" class="nav-dropdown-link">会社方針</a>
                        <a href="/#company" class="nav-dropdown-link">企業概要</a>
                        <a href="/#strength" class="nav-dropdown-link--last">選ばれる理由</a>
                    </div>
                </div>

                <!-- 事業内容 -->
                <div class="relative group py-2">
                    <a href="/#service" class="nav-dropdown-trigger">事業内容</a>
                    <div class="nav-dropdown-menu w-48">
                        <a href="/#service" class="nav-dropdown-link">事業内容</a>
                        <a href="/#works" class="nav-dropdown-link">開発・製作実績</a>
                        <a href="/#workflow" class="nav-dropdown-link--last">ご依頼の流れ</a>
                    </div>
                </div>
                
                <!-- 特設・イベント -->
                <div class="relative group py-2">
                    <a href="/#special" class="nav-dropdown-trigger">特設・イベント</a>
                    <div class="nav-dropdown-menu w-56">
                        <a href="/#special" class="nav-dropdown-link">特設・イベント</a>
                        <a href="/infection" class="nav-dropdown-link">感染症対策</a>
                        <a href="/events" class="nav-dropdown-link--last">イベント＆お知らせ</a>
                    </div>
                </div>

                <a href="/#recruit" class="nav-link">採用情報</a>
                <a href="/#access" class="nav-link">アクセス</a>

                <!-- お問い合わせボタン（すでに common.css の btn-primary を使ってもOKですが、少し形が違うので直接指定を残します） -->
                <!-- <a href="#contact" class="bg-accent hover:bg-accent-hover text-white px-6 py-2 rounded-full transition shadow-lg transform hover:-translate-y-0.5">
                    お問い合わせ
                </a> -->
                <a href="/#contact" class="btn-primary-sm">お問い合わせ</a>
            </nav>

            <!-- モバイルメニュー用ボタン -->
            <div class="xl:hidden">
                <button id="menu-btn" type="button" class="mobile-menu-btn" aria-label="メニューを開く">
                    <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- モバイルメニュー -->
        <div id="mobile-menu" class="mobile-menu hidden">
            <div class="mobile-menu-heading">企業情報</div>
            <a href="/#about" class="mobile-menu-link">会社方針</a>
            <a href="/#company" class="mobile-menu-link">企業概要</a>
            <a href="/#strength" class="mobile-menu-link">選ばれる理由</a>
            
            <div class="mobile-menu-heading">事業内容</div>
            <a href="/#service" class="mobile-menu-link">事業内容トップ</a>
            <a href="/#works" class="mobile-menu-link">開発・製作実績</a>
            <a href="/#workflow" class="mobile-menu-link">ご依頼の流れ</a>
            
            <div class="mobile-menu-heading">特設・イベント</div>
            <a href="/#special" class="mobile-menu-link">特設・イベント</a>
            <a href="/infection" class="mobile-menu-link">感染症対策</a>
            <a href="/events" class="mobile-menu-link">イベント＆お知らせ</a>
            
            <div class="mobile-menu-heading">その他</div>
            <a href="/#recruit" class="mobile-menu-link">採用情報</a>
            <a href="/#access" class="mobile-menu-link">アクセス</a>
            <a href="#contact" class="mobile-menu-link--last">お問い合わせ</a>
        </div>
    </header>

    <slot />

    <!-- フッター -->
    <footer class="bg-primary py-16 border-t border-primary">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12 mb-12">
                
                <!-- 会社情報（画面左） -->
                <div class="md:col-span-1">
                    <h3 class="text-2xl font-bold text-text-inverse mb-6">株式会社 新二ホンテック</h3>
                    <!-- ★ footer-text を適用（mb-4 は固有の余白なので残す） -->
                    <p class="footer-text mb-4">
                        〒400-0057<br>
                        山梨県甲府市高室町688-2<br>
                    </p>
                    <p class="footer-text font-mono">
                        TEL: 055-241-9231<br>
                        FAX: 055-241-9223
                    </p>
                </div>

                <!-- サイトマップ（画面中央） -->
                <div class="md:col-span-2">
                    <h4 class="footer-heading">サイトマップ</h4>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
                        <!-- フッターリンク共通クラス適用 -->
                        <ul class="space-y-3">
                            <li><a href="/#about" class="footer-link">会社方針</a></li>
                            <li><a href="/#company" class="footer-link">企業概要</a></li>
                            <li><a href="/#strength" class="footer-link">選ばれる理由</a></li>
                        </ul>
                        <ul class="space-y-3">
                            <li><a href="/#service" class="footer-link">事業内容</a></li>
                            <li><a href="/#works" class="footer-link">開発・製作実績</a></li>
                            <li><a href="/#workflow" class="footer-link">ご依頼の流れ</a></li>
                        </ul>
                        <ul class="space-y-3">
                            <li><a href="/#special" class="footer-link">特設・イベント</a></li>
                            <li><a href="/infection" class="footer-link">感染症対策</a></li>
                            <li><a href="/events" class="footer-link">イベント＆お知らせ</a></li>
                            <li><a href="/#recruit" class="footer-link">採用情報</a></li>
                            <li><a href="/#access" class="footer-link">アクセス</a></li>
                        </ul>
                    </div>
                </div>

                <!-- 関連リンク（画面右） -->
                <div class="md:col-span-1 flex flex-col justify-between">
                    <div>
                        <!-- 関連リンクの見出し -->
                        <h4 class="footer-heading">関連リンク</h4>
                        
                        <!-- ボタン（★ 透過カードクラスを適用） -->
                        <a href="https://www.e-kuri.com/" target="_blank" rel="noopener noreferrer" class="card--transparent group mb-4">
                            <i class="fas fa-building text-text-muted group-hover:text-white mr-4 text-xl transition"></i>
                            <div>
                                <span class="block text-[10px] text-accent mb-0.5 font-bold tracking-wider">グループ会社</span>
                                <span class="block text-sm text-white font-bold">株式会社 E-クリエイト</span>
                            </div>
                        </a>
                    </div>
                    
                    <!-- ページトップへ戻るボタン -->
                    <div class="text-right mt-8">
                        <!-- ★ 透過ボタンクラスを適用 -->
                        <a href="/" class="btn-transparent w-full md:w-auto">
                            <i class="fas fa-arrow-up mr-2"></i> ページトップへ
                        </a>
                    </div>
                </div>

            </div>
            
            <!-- ★ footer-copyright を適用 -->
            <div class="footer-copyright">
                <p>© SHINNIHONTEC CO., LTD. All Rights Reserved.</p>
            </div>
        </div>
    </footer>

    <!-- 全ページ共通のスクリプト（ヘッダーのモバイルメニュー開閉など） -->
    <script src="/assets/js/common.js" is:inline></script>

</body>
</html>